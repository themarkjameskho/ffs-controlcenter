{
  "name": "fast-forward-control-center",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint --max-warnings=0 \"src/**/*.{ts,tsx}\"",
    "preview": "vite preview",
    "orders:build": "node ./scripts/build-order-registry.mjs",
    "orders:plan": "node ./scripts/plan-agent-distribution.mjs",
    "check:tasks": "node ./scripts/check-tasks.mjs",
    "snapshot:build": "node ./scripts/build-vercel-snapshot.mjs",
    "sanity:sync": "node ./scripts/sanity-sync.mjs",
    "sanity:sync:dry": "node ./scripts/sanity-sync.mjs --dry-run"
  },
  "dependencies": {
    "@sanity/client": "^7.9.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
